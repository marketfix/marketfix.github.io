    "advertising_predictions.html": {
      "settings": {
        "title": "Advertising predictions in 2023",
        "order": 6,
        "meta_descr": "The most popular advertising trends will likely include traditional and modern techniques. Traditional advertising techniques such as print ads, television commercials, and radio ads will still be used. Still, they will be supplemented with modern techniques such as online advertising, social media marketing, and content marketing. As consumers become more media-savvy, they will increasingly ignore traditional advertising techniques that are not relevant to their interests or needs. This means that advertisers will need to be more creative and strategic in their approach to reach their target audiences. Some of the most popular advertising trends next year should include the following."
      },
      "components": [
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)"
            },
            ".card-wrapper": {
              "background": "@wrapBgColor",
              "border-radius": "4px",
              "@media (max-width: 767px)": {
                "padding": "1rem"
              },
              "@media (min-width: 768px) and (max-width: 991px)": {
                "padding": "2rem"
              },
              "@media (min-width: 992px)": {
